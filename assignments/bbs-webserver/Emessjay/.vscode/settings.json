{
  // Point Pylance / the Python extension at the project venv so imports
  // like `httpx`, `fastapi`, `pydantic`, and `pytest` resolve instead of
  // showing red squiggles.  Without this, VSCode falls back to the
  // system Python, which has none of the project's dependencies.
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",

  // webserver/ is not a package (no __init__.py), so `from db import ...`
  // inside webserver/main.py and `import main` inside webserver/conftest.py
  // look unresolvable to Pylance's static analyser.  At runtime, the
  // pytest fixture in conftest.py prepends HERE to sys.path — but
  // Pylance does not execute that code.  Telling it to treat webserver/
  // as an extra source root makes both imports resolve without us
  // having to turn the directory into a package.
  "python.analysis.extraPaths": [
    "${workspaceFolder}/webserver"
  ]
}
